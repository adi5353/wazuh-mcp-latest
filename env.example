# ============================================================================
# Wazuh Manager API
# ============================================================================
WAZUH_HOST=https://your-wazuh-manager-ip:55000
WAZUH_USER=your_wazuh_username
WAZUH_PASS=your_wazuh_password

# ============================================================================
# Wazuh Indexer (OpenSearch)
# ============================================================================
WAZUH_INDEXER_HOST=https://your-wazuh-indexer-ip:9200
WAZUH_INDEXER_USER=your_indexer_username
WAZUH_INDEXER_PASS=your_indexer_password

# Optional — override default index patterns
WAZUH_ALERTS_INDEX=wazuh-alerts-*
WAZUH_VULN_INDEX=wazuh-states-vulnerabilities-*

# Archive logs index (used by search_archive_logs tool)
# Requires archiving enabled in ossec.conf
WAZUH_ARCHIVES_INDEX=wazuh-archives-*

# Inventory state indices (Wazuh 4.10+ only — older versions will return errors
# from the fleet_* inventory tools, but per-agent inventory tools still work)
WAZUH_INV_PACKAGES_INDEX=wazuh-states-inventory-packages-*
WAZUH_INV_PROCESSES_INDEX=wazuh-states-inventory-processes-*
WAZUH_INV_PORTS_INDEX=wazuh-states-inventory-ports-*

# ============================================================================
# MCP Server Transport
# ============================================================================
# Transport mode: "http" for remote/SSE (recommended), "stdio" for local use
WAZUH_MCP_TRANSPORT=http

# Host to bind on. Use 0.0.0.0 for remote access (VM, separate host),
# or 127.0.0.1 if Claude Desktop runs on the same machine.
# NOTE: The MCP SDK's DNS-rebinding protection is disabled in server.py so
# that non-localhost Host headers (e.g. 192.168.x.x) are accepted. This is
# safe on trusted private networks. See README Issue #14 for details.
WAZUH_MCP_HOST=0.0.0.0
WAZUH_MCP_PORT=8000

# ============================================================================
# Operational
# ============================================================================
# Verify TLS certificates.
# DEFAULT IS NOW TRUE — set false only in local dev/lab with self-signed certs.
# For custom CA chains, set WAZUH_CA_BUNDLE to the PEM file path instead.
WAZUH_VERIFY_SSL=true
# WAZUH_CA_BUNDLE=/etc/ssl/wazuh-ca.pem   # Path to custom CA cert bundle (PEM)

# Enable write/destructive tools: restart_agent, run_active_response,
# add_to_cdb_list, remove_from_cdb_list.
# Keep false until you trust the LLM agent's judgement.
WAZUH_ALLOW_WRITES=false

# Per-request timeout (seconds)
WAZUH_REQUEST_TIMEOUT=30

# ============================================================================
# Threat Intelligence (optional)
# ============================================================================
# Required by enrich_ip and enrich_file_hash tools.
# Both are optional — tools return a clear message if keys are absent.
#
# VirusTotal free tier: 500 lookups/day — https://virustotal.com
VIRUSTOTAL_API_KEY=

# AbuseIPDB free tier: 1000 lookups/day — https://abuseipdb.com
ABUSEIPDB_API_KEY=

# ── New in enhanced edition ────────────────────────────────────────────
WAZUH_MAX_RESULTS_GLOBAL=500
LOG_LEVEL=INFO
WAZUH_MCP_API_KEY=

# ── Security hardening (optional) ─────────────────────────────────
# Path for structured audit log (JSONL — one line per MCP tool call)
WAZUH_AUDIT_LOG=logs/audit.jsonl

# Rate limiting — requests per minute per API-key identity (sliding 60-second window)
WAZUH_MCP_RATE_LIMIT_RPM=60
WAZUH_MCP_RATE_LIMIT_BURST=10

# Role-based access control — controls which tool tier this server instance exposes.
# Tiers (ascending privilege): viewer | analyst | responder | admin
# Default: analyst  (read + enrichment + hunt; no writes or active response)
WAZUH_MCP_USER_ROLE=analyst

# ── SOAR / Ticketing ─────────────────────────────────────────────
JIRA_URL=https://your-domain.atlassian.net
JIRA_USER=soc@your-domain.com
JIRA_API_TOKEN=                    # From id.atlassian.com/manage-profile/security/api-tokens
JIRA_PROJECT_KEY=SOC

THEHIVE_URL=http://your-thehive-ip:9000
THEHIVE_API_KEY=

# Slack — webhook is simpler (one URL, no OAuth)
SLACK_WEBHOOK_URL=                 # https://hooks.slack.com/services/T.../B.../xxx
# Alternative: bot token (needs chat:write scope)
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=#soc-alerts
SLACK_SOC_CHANNEL=#soc-handover
SLACK_MGMT_CHANNEL=#security-mgmt

# ── Email report delivery ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=soc@your-domain.com
SMTP_PASS=                         # Gmail: use App Password (myaccount.google.com/apppasswords)
REPORT_EMAIL_FROM=soc@your-domain.com
REPORT_EMAIL_TO=ciso@your-domain.com     # Comma-separated for multiple

# ── Agent enrollment ──────────────────────────────────────────────
WAZUH_REGISTRATION_PASSWORD=       # Leave blank if not using enrollment passwords
