# ============================================================
# Wazuh MCP Server — environment variable reference
# Copy to .env and fill in your values.
# ============================================================

# ── Wazuh Manager API (required) ────────────────────────────
WAZUH_HOST=https://your-wazuh-manager:55000
WAZUH_USER=wazuh
WAZUH_PASS=your_manager_password

# ── Wazuh Indexer / OpenSearch (required) ───────────────────
WAZUH_INDEXER_HOST=https://your-wazuh-indexer:9200
WAZUH_INDEXER_PASS=your_indexer_password
WAZUH_INDEXER_USER=wazuh-readonly        # optional, default: wazuh-readonly

# ── Index names (optional — defaults shown) ──────────────────
WAZUH_ALERTS_INDEX=wazuh-alerts-*
WAZUH_VULN_INDEX=wazuh-states-vulnerabilities-*
WAZUH_INV_PACKAGES_INDEX=wazuh-states-inventory-packages-*
WAZUH_INV_PROCESSES_INDEX=wazuh-states-inventory-processes-*
WAZUH_INV_PORTS_INDEX=wazuh-states-inventory-ports-*

# ── TLS / SSL ────────────────────────────────────────────────
WAZUH_VERIFY_SSL=true
# WAZUH_CA_BUNDLE=/path/to/ca-bundle.pem   # custom CA cert

# ── Operations ───────────────────────────────────────────────
WAZUH_ALLOW_WRITES=false                 # set true to enable destructive tools
WAZUH_REQUEST_TIMEOUT=30
WAZUH_MAX_RESULTS_GLOBAL=500

# ── RBAC — single-user mode ──────────────────────────────────
WAZUH_MCP_USER_ROLE=viewer               # viewer | analyst | responder | admin (default: viewer)

# ── RBAC — multi-user mode (optional) ───────────────────────
# WAZUH_MCP_KEY_MAP=viewer:key_abc,analyst:key_def,admin:key_xyz

# ── MCP transport ────────────────────────────────────────────
WAZUH_MCP_TRANSPORT=stdio                # stdio | http
WAZUH_MCP_HOST=0.0.0.0
WAZUH_MCP_PORT=8000
# WAZUH_MCP_API_KEY=your_bearer_token    # single global bearer token (HTTP mode)

# ── Secrets backend (optional) ───────────────────────────────
# WAZUH_SECRET_BACKEND=vault             # vault | aws | (unset = env vars)
# VAULT_ADDR=https://vault.internal:8200
# VAULT_TOKEN=your_vault_token
# VAULT_SECRET_PATH=secret/wazuh-mcp
# AWS_SECRET_NAME=wazuh-mcp/secrets
# AWS_REGION=us-east-1

# ── Threat intelligence APIs (optional) ──────────────────────
# VIRUSTOTAL_API_KEY=your_vt_key
# ABUSEIPDB_API_KEY=your_abuse_key
VIRUSTOTAL_DAILY_LIMIT=450              # free tier: 500/day
ABUSEIPDB_DAILY_LIMIT=900               # free tier: 1000/day
TI_CIRCUIT_FAIL_THRESHOLD=5
TI_CIRCUIT_RESET_SECONDS=300

# ── SOAR integrations (optional) ─────────────────────────────
# JIRA_URL=https://yourcompany.atlassian.net
# JIRA_USER=your@email.com
# JIRA_API_TOKEN=your_jira_token
# JIRA_PROJECT_KEY=SOC

# THEHIVE_URL=https://your-thehive:9000
# THEHIVE_API_KEY=your_thehive_key

# SNOW_INSTANCE=yourinstance             # ServiceNow
# SNOW_USER=admin
# SNOW_PASS=your_snow_password

# PAGERDUTY_ROUTING_KEY=your_pd_key

# ── Slack notifications (optional) ───────────────────────────
# SLACK_BOT_TOKEN=xoxb-your-token
# SLACK_ALERT_CHANNEL=#soc-alerts

# ── Email reports (optional) ─────────────────────────────────
# SMTP_HOST=smtp.yourcompany.com
# SMTP_PORT=587
# SMTP_USER=alerts@yourcompany.com
# SMTP_PASS=your_smtp_password
# SMTP_FROM=wazuh-mcp@yourcompany.com

# ── Azure DevOps (optional) ──────────────────────────────────
# AZURE_DEVOPS_ORG=yourorg
# AZURE_DEVOPS_PROJECT=YourProject
# AZURE_DEVOPS_PAT=your_pat_token

# ── Workspace / state persistence ────────────────────────────
WAZUH_WORKSPACE_DIR=/app/workspaces      # writable dir for workspaces + state

# ── Logging ──────────────────────────────────────────────────
WAZUH_AUDIT_LOG=logs/audit.jsonl
# WAZUH_MCP_LOG_LEVEL=INFO

# ── Network access controls (HTTP mode) ──────────────────────
# WAZUH_MCP_ALLOWED_IPS=192.168.1.0/24,10.0.0.5
# WAZUH_MCP_BLOCKED_IPS=1.2.3.4

# ── Playbooks ────────────────────────────────────────────────
# WAZUH_PLAYBOOKS_DIR=/app/playbooks     # custom YAML playbooks dir
