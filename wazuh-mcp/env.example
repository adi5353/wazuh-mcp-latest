# ============================================================================
# Wazuh Manager API
# ============================================================================
WAZUH_HOST=https://wazuh-manager.example.com:55000
WAZUH_USER=wazuh-api-readonly
WAZUH_PASS=change-me

# ============================================================================
# Wazuh Indexer (OpenSearch)
# ============================================================================
WAZUH_INDEXER_HOST=https://wazuh-indexer.example.com:9200
WAZUH_INDEXER_USER=wazuh-readonly
WAZUH_INDEXER_PASS=change-me

# Optional — override default index patterns
WAZUH_ALERTS_INDEX=wazuh-alerts-*
WAZUH_VULN_INDEX=wazuh-states-vulnerabilities-*

# Archive logs index (used by search_archive_logs tool)
# Requires archiving enabled in ossec.conf
WAZUH_ARCHIVES_INDEX=wazuh-archives-*

# Inventory state indices (Wazuh 4.10+ only — older versions will return errors
# from the fleet_* inventory tools, but per-agent inventory tools still work)
WAZUH_INV_PACKAGES_INDEX=wazuh-states-inventory-packages-*
WAZUH_INV_PROCESSES_INDEX=wazuh-states-inventory-processes-*
WAZUH_INV_PORTS_INDEX=wazuh-states-inventory-ports-*

# ============================================================================
# MCP Server Transport
# ============================================================================
# Transport mode: "http" for remote/SSE (recommended), "stdio" for local use
WAZUH_MCP_TRANSPORT=http

# Host to bind on. Use 0.0.0.0 for remote access (VM, separate host),
# or 127.0.0.1 if Claude Desktop runs on the same machine.
# NOTE: The MCP SDK's DNS-rebinding protection is disabled in server.py so
# that non-localhost Host headers (e.g. 192.168.x.x) are accepted. This is
# safe on trusted private networks. See README Issue #14 for details.
WAZUH_MCP_HOST=0.0.0.0
WAZUH_MCP_PORT=8000

# ============================================================================
# Operational
# ============================================================================
# Verify TLS certificates. Set true in production with proper CA chain.
WAZUH_VERIFY_SSL=false

# Enable write/destructive tools: restart_agent, run_active_response,
# add_to_cdb_list, remove_from_cdb_list.
# Keep false until you trust the LLM agent's judgement.
WAZUH_ALLOW_WRITES=false

# Per-request timeout (seconds)
WAZUH_REQUEST_TIMEOUT=30

# ============================================================================
# Threat Intelligence (optional)
# ============================================================================
# Required by enrich_ip and enrich_file_hash tools.
# Both are optional — tools return a clear message if keys are absent.
#
# VirusTotal free tier: 500 lookups/day — https://virustotal.com
VIRUSTOTAL_API_KEY=

# AbuseIPDB free tier: 1000 lookups/day — https://abuseipdb.com
ABUSEIPDB_API_KEY=
